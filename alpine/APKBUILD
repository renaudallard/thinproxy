pkgname=thinproxy
pkgver=0.1.2
pkgrel=0
pkgdesc="Lightweight asynchronous HTTP/HTTPS proxy"
url="https://github.com/renaudallard/thinproxy"
arch="all"
license="BSD-2-Clause"
makedepends="gcc make linux-headers"
source="$pkgname-$pkgver.tar.gz"
builddir="$srcdir/$pkgname-$pkgver"

build() {
	make
}

check() {
	./thinproxy -V
	strings thinproxy | grep -q 'prctl(SECCOMP)'
}

package() {
	make install DESTDIR="$pkgdir" PREFIX=/usr UNITDIR=/usr/lib/systemd/system
	gzip "$pkgdir"/usr/share/man/man8/thinproxy.8
}
